<div class="edo-skill-editor">
    <div class="flexcol edo-skill-list flex-gap-l">
        {{#each system.skills as |skill key|}}
            <div class="flexrow flex-gap-m">

                {{systemFieldInput @root.system (concat 'skills.' key '.name')}}
                {{systemFieldInput @root.system (concat 'skills.' key '.rank')}}
            </div>
        {{/each}}
    </div>
    <div class="flexrow">
        <div><button type="button" data-action="create"><i class="fas fa-plus"></i></button></div>
    </div>
</div>