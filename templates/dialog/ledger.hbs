<div style="height: 100%;" class="newedo">
    <div class="header flexrow flex-gap-xl" style="margin-bottom: 12px;">

        <h1 class="flexshrink nowrap" style="border: 0; margin: 0; flex: 0; white-space: nowrap;">{{localize label}}: {{sum}}</h1>
        <div class="atm flexcol flex-gap-xs">
            <div class="currency flexrow">
                <input name="value" style="flex: 3; margin-right: 4px;" type="number" min="0" placeholder="0" />
                <div class="flexrow flex align-center flex-gap-xs">
                    <a class="flex-align-center" data-operation="+"><i class="fa-solid fa-plus"></i></a>
                    <a class="flex-align-center" data-operation="-"><i class="fa-solid fa-minus"></i></a>
                    <a class="flex-align-center" data-operation="="><i class="fa-solid fa-equals"></i></a>
                </div>
            </div>
            <input name="note" type="text" placeholder="balance change note" />
        </div>
    </div>
    <div class="transactions scrollable flex" style="height: calc(100% - 100px);">
        <span class="flexrow flex-gap" style="border: 2px groove white; padding: 5px 10px;">
            <span class="flexshrink" data-action="sortById">ID</span>
            <span class="flex" data-action="sortByUser">Date</span>
            <span data-action="sortByUser">Value</span>
            <span data-action="sortByUser">User</span>
            <span data-action="sortByUser" style="flex: 4;">Note</span>
            {{#if (isGM)}}
                <span class="flex">Admin</span>
            {{/if}}
        </span>
        <ol class="flexcol flex-end" style="padding: 0 10px; margin: 10px 0;">
            {{#each transactions as | record key |}}
                <li data-index="{{record.id}}" class="flexrow flex-gap align-start">
                    <span style="margin-right: 10px; min-width: 100px;" class="flexrow flex-gap-xl nowrap flexshrink">
                        <span class="flexshrink">{{record.id}}</span>
                        <span class="flex">{{record.date}}</span>
                    </span>
                    <span class="flexrow flex-gap-l flexlarge">
                        <span class="flexrow flex flex-align-center">
                            {{record.operation}} {{record.value}}
                        </span>
                        <span class="flex">{{record.user}}</span>
                        <span style="flex: 4">{{record.note}}</span>
                        {{#if (isGM)}}
                            <a class="flexshrink" data-action="deleteIndex"><i class="fa-solid fa-trash"></i></a>
                        {{/if}}
                    </span>
                </li>
            {{/each}}
        </ol>
    </div>
</div>