<div class="edo-tab-content edo-item-settings edo-path-settings flex-gap-m">
    <div class="flexrow" style="border: 2px groove white; padding: 8px;">
        <div class="text-left">Name</div>
        <a class="text-right" data-action="createFeature">Add Feature</a>
    </div>
    <ol class="feature-list">
        {{#each features as | feature key | }}
            <li class="feature" data-feature-id="{{key}}">
                <div class="header flexrow">
                    <a data-action="collapse">
                        {{#if (eq feature.type 'trait')}}<i class="fas fa-hand-fist"></i>{{/if}}
                        {{#if (eq feature.type 'item')}}<i class="fas fa-box"></i>{{/if}}
                        {{feature.label}}
                    </a>
                    <span>{{feature.type}}</span>
                    <span>Rank: {{feature.unlock}}</span>
                    <span class="flexrow flexshrink flex-nowrap flex-gap-xs">
                        <a class="flex" data-action="editFeature"><i class="fas fa-edit"></i></a>
                        {{#if ../isEditMode}}<a class="flex" data-action="deleteFeature"><i class="fas fa-trash"></i></a>{{/if}}
                    </span>
                </div>
                <div class="details">
                    <div class="inner">Details go here</div>
                </div>
            </li>
        {{/each}}
    </ol>
</div>