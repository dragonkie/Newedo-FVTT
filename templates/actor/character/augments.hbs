<div class="edo-tab-content">
    {{!-- Ammount of trait noise the character has gathered --}}

    <div class="flexrow flex-gap-m nowrap">
        {{#each system.traits.core as | trait key |}}
            {{#unless (eq key 'shi')}}
                <div class="flexcol flex-align-center">
                    <label class="edo-resource-label" data-action="roll" data-roll="{{trait.rank}}d10x10" data-roll-type="{{trait.label}}">{{trait.label}}</label>
                    <input class="flex-align-center" type="number" value="{{trait.noise}}" disabled>
                </div>
            {{/unless}}
        {{/each}}
    </div>

    {{!-- List of augments the character has --}}
    <ol class="items-list">
        <li class="items-header flexrow collapsible">
            <span>Augment</span>
            <span>Noise</span>
            <span>Biofeedback</span>
            <span>Install</span>
        </li>
        {{#each itemTypes.augment as | augment key |}}

            <li class="item flexrow" data-item-uuid="{{augment.uuid}}">
                {{!-- Link to the fate opens up the item sheet --}}
                <span class="flexrow align-center flex-start item-name flex-gap-xs" data-action="edit">
                    <img class="flexshrink" src="{{augment.img}}" width="30" height="30">
                    <h4>{{augment.name}}</h4>
                </span>
                <span class="item-detail">{{augment.system.biofeedback}}%</span>

                <span class="item-controls flex-gap-s">
                    {{log 'rendering aug entry' augment}}
                    {{#if (not augment.system.installed) }} <span data-action="use" data-use="install"><i class="fa-solid fa-microchip"></i></span> {{/if}}
                    {{#if augment.system.installed}} <span data-action="use" data-use="install"><i class="fa-solid fa-circle-minus"></i></span> {{/if}}
                    {{#if @root.isEditMode}} <span class="item-delete"><i class="fa-solid fa-trash"></i></span> {{/if}}
                </span>
            </li>

        {{/each}}
    </ol>

</div>