<div class="edo-tab-content">
    <li class="items-header flexrow collapsible">
        <span>Rote</span>
        <span>Skill</span>
        <span>TN</span>
        <span>Cost</span>
        <span>Controls</span>
    </li>
    <ol class="items-list">
        {{#each itemTypes.rote as | rote key |}}

            <li class="item flexrow text-center" data-item-uuid="{{rote.uuid}}">
                {{!-- Link to the fate opens up the item sheet --}}
                <span class="flexrow align-center flex-start item-name flex-gap-xs" data-action="edit">
                    <img class="flexshrink" src="{{rote.img}}" width="30" height="30">
                    <h4>{{rote.name}}</h4>
                </span>

                <a class="item-detail" data-action="use" data-label="{{rote.name}}">{{rote.system.skill.label}}</a>
                <span class="item-detail">{{rote.system.tn}}</span>
                <span class="item-detail">{{rote.system.casting.cost}}</span>

                <span class="item-controls">
                    <a data-action="use" data-use="cast"><i class="fa-solid fa-book-blank"></i></a>
                    {{#if ../isEditMode}}<a data-action="delete"><i class="fa-solid fa-trash"></i></a>{{/if}}
                </span>

            </li>

        {{/each}}
    </ol>
</div>