<div class="edo-tab-content">
    <li class="items-header flexrow collapsible">
        <span>Weapons</span>
        <span>Skill</span>
        <span>Controls</span>
    </li>
    <ol class="items-list">

        {{#each itemTypes.weapon as | weapon key |}}

            <li class="item flexrow text-center" data-item-uuid="{{weapon.uuid}}">

                <span class="flexrow align-center flex-start">
                    <img src="{{weapon.img}}" width="30" height="30">
                    <a style="margin-left: 4px;" data-action="edit">{{weapon.name}}</a>
                </span>

                <span class="text-left">
                    {{localize weapon.system.skill.label}}
                </span>

                <span class="item-controls">

                    <a data-action="use" data-use="equip">
                        {{#if weapon.isEquipped}}<i class="fa-solid fa-hand-rock"></i>{{/if}}
                        {{#if (not weapon.isEquipped)}}<i class="fa-solid fa-hand"></i>{{/if}}
                    </a>

                    <a data-action="use" data-use="attack">
                        {{#if weapon.isRanged}}<i class="fa-solid fa-gun"></i>{{/if}}
                        {{#if (not weapon.isRanged)}}<i class="fa-solid fa-sword"></i>{{/if}}
                    </a>

                    <a data-action="use" data-use="damage">
                        {{#if weapon.isRanged}}<i class="fa-solid fa-crosshairs"></i>{{/if}}
                        {{#if (not weapon.isRanged)}}<i class="fa-solid fa-droplet"></i>{{/if}}
                    </a>

                    {{#if ../isEditMode}}<a data-action="delete"><i class="fa-solid fa-trash"></i></a>{{/if}}

                </span>
            </li>

        {{/each}}
    </ol>
</div>